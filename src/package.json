{
  "name": "otto-ppc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create otto_ppc",
    "db:migrate": "wrangler d1 execute otto_ppc --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute otto_ppc --local --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.0.0"
  }
}
